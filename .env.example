# Librarfree — environment configuration (Phase 0)
# Copy to .env.local and fill values. Never commit real secrets.

NODE_ENV=development

# ── Database (Supabase Postgres) ───────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/librarfree
DATABASE_POOLER_URL=

# ── Supabase Auth / REST ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Meilisearch ────────────────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_ADMIN_KEY=librarfreeDevKey
MEILI_MASTER_KEY=librarfreeDevKey

# ── Object storage (MinIO local / Cloudflare R2 prod) ──────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=librarfree
S3_SECRET_KEY=librarfree-dev-password
S3_BUCKET_CONTENT=books-content
S3_BUCKET_COVERS=books-covers
S3_BUCKET_EXPORTS=books-exports
S3_FORCE_PATH_STYLE=true

# ── Upstash Redis (cache / rate-limit) ─────────────────────────────
REDIS_URL=

# ── Importers ──────────────────────────────────────────────────────
GUTENBERG_MIRROR=https://www.gutenberg.org

# ── Ollama (Phase 4 embeddings / summaries) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5
OLLAMA_SUMMARY_MODEL=llama3.2:3b

# ── Stripe (Phase 4 premium + donations) ───────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Affiliation (Phase 2) ──────────────────────────────────────────
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_ASSOCIATE_TAG_US=
AMAZON_ASSOCIATE_TAG_FR=
AMAZON_ASSOCIATE_TAG_DE=
AMAZON_ASSOCIATE_TAG_ES=
AMAZON_ASSOCIATE_TAG_UK=
AMAZON_ASSOCIATE_TAG_IT=
AMAZON_ASSOCIATE_TAG_JP=

# ── Analytics / monitoring (Phase 3+) ──────────────────────────────
PLAUSIBLE_DOMAIN=
SENTRY_DSN=

# ── Public app URL (used in metadata, OG, sitemaps) ────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

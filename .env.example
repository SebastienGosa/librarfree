# Librarfree Environment Configuration
# Copy to .env.local and fill values

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/librarfree

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=changeme

# Ollama (for embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5
OLLAMA_SUMMARY_MODEL=llama3.2:3b

# Amazon PAAPI (optional)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_ASSOCIATE_TAG_US=
AMAZON_ASSOCIATE_TAG_FR=
AMAZON_ASSOCIATE_TAG_DE=
AMAZON_ASSOCIATE_TAG_ES=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production
NODE_ENV=development

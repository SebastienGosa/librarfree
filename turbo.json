{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env.*local",
    ".env",
    "tsconfig.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "DATABASE_URL",
    "DATABASE_POOLER_URL",
    "MEILI_URL",
    "MEILI_ADMIN_KEY",
    "MEILI_MASTER_KEY",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET_CONTENT",
    "S3_BUCKET_COVERS",
    "S3_BUCKET_EXPORTS",
    "S3_FORCE_PATH_STYLE",
    "REDIS_URL",
    "GUTENBERG_MIRROR",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.*local",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/*.spec.ts"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts"
      ],
      "outputs": ["coverage/**"]
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:seed": {
      "cache": false
    },
    "import:gutenberg": {
      "cache": false
    },
    "import:standard-ebooks": {
      "cache": false
    },
    "import:gallica": {
      "cache": false
    },
    "import:wikisource": {
      "cache": false
    },
    "embeddings": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
